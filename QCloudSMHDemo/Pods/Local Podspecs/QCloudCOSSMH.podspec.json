{
  "name": "QCloudCOSSMH",
  "version": "1.0.9",
  "summary": "QCloudCOSSMH 腾讯云iOS-SDK组件",
  "description": "TODO: Add long description of the pod here.aaa",
  "pod_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64"
  },
  "homepage": "https://cloud.tencent.com/",
  "license": "MIT",
  "authors": {
    "QCloudTerminalLab": "g_PDTC_storage_DEV_terminallab@tencent.com"
  },
  "source": {
    "git": "http://git.woa.com/qcloud-terminal/QCloudiOSCodes/tree/develop/BisnessComponents/COSSMH/QCloudCOSSMH",
    "branch": "develop-SMH-SDK"
  },
  "platforms": {
    "ios": "9.0"
  },
  "static_framework": true,
  "default_subspecs": "Default",
  "subspecs": [
    {
      "name": "Default",
      "source_files": "Pod/Classes/**/*",
      "exclude_files": [
        "Pod/Classes/Api/QCloudCOSSMHApi.h",
        "Pod/Classes/User/QCloudCOSSMHUser.h"
      ],
      "dependencies": {
        "QCloudCore": [
          "6.5.4"
        ]
      }
    },
    {
      "name": "WithoutCoreVersion",
      "source_files": "Pod/Classes/**/*",
      "exclude_files": [
        "Pod/Classes/Api/QCloudCOSSMHApi.h",
        "Pod/Classes/User/QCloudCOSSMHUser.h"
      ],
      "dependencies": {
        "QCloudCore": [

        ]
      }
    },
    {
      "name": "Slim",
      "source_files": "Pod/Classes/**/*",
      "exclude_files": [
        "Pod/Classes/Api/QCloudCOSSMHApi.h",
        "Pod/Classes/User/QCloudCOSSMHUser.h"
      ],
      "dependencies": {
        "QCloudCore/WithoutMTA": [
          "6.5.4"
        ]
      }
    },
    {
      "name": "Api",
      "source_files": [
        "Pod/Classes/Api/*",
        "Pod/Classes/Api/**/*",
        "Pod/Classes/QCloudCOSSMHVersion.*",
        "Pod/Classes/Common/*",
        "Pod/Classes/Common/**/*"
      ],
      "dependencies": {
        "QCloudCore/WithoutMTA": [
          "6.5.4"
        ]
      }
    }
  ]
}
